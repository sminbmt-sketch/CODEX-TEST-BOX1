# Application
APP_ENV=development
APP_NAME=SecureWatch MVP
API_HOST=0.0.0.0
API_PORT=8000
# Add the deployed dashboard origin, for example http://10.10.10.63:5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional. Set this only when Podman/Docker DNS cannot resolve external domains.
BACKEND_DNS=

# Database
POSTGRES_DB=securewatch
POSTGRES_USER=securewatch
POSTGRES_PASSWORD=securewatch_dev_password
DATABASE_URL=postgresql+psycopg://securewatch:securewatch_dev_password@postgres:5432/securewatch

# Security data sources
NVD_API_KEY=
GITHUB_TOKEN=

# Tanium - never commit real tokens
TANIUM_BASE_URL=https://tanium.example.internal
TANIUM_API_TOKEN=
TANIUM_GATEWAY_PATH=/plugin/products/gateway/graphql
TANIUM_VERIFY_TLS=false
TANIUM_TIMEOUT_SECONDS=30

# LLM
LLM_PROVIDER=disabled
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b
LLM_API_KEY=
